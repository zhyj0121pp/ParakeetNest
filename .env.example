# ParakeetNest local integration example.
# Copy to .env locally and fill real values there. Never commit credentials.

PARAKEETNEST_APP_NAME=ParakeetNest
PARAKEETNEST_ENVIRONMENT=development
PARAKEETNEST_LOG_LEVEL=INFO
PARAKEETNEST_LOG_JSON=true
PARAKEETNEST_DATA_DIR=data
PARAKEETNEST_SQLITE_PATH=data/parakeetnest.sqlite3

OPENAI_API_KEY=
PARAKEETNEST_LLM_PROVIDER=mock
PARAKEETNEST_LLM_MODEL=mock-committee
PARAKEETNEST_LLM_TEMPERATURE=0.0
FRED_API_KEY=

# Path to the Google OAuth client credentials JSON.
GOOGLE_APPLICATION_CREDENTIALS=

# Path to the authorized-user OAuth token JSON used by the Gmail send provider.
PARAKEETNEST_GMAIL_TOKEN_PATH=

# SEC requires an identifying User-Agent, usually app name plus contact email.
# Quote the value in .env if it contains spaces.
SEC_USER_AGENT=

# Robinhood read-only portfolio provider. Prefer a short-lived session token
# when available; otherwise use username and password from local environment.
ROBINHOOD_USERNAME=
ROBINHOOD_PASSWORD=
ROBINHOOD_SESSION_TOKEN=
ROBINHOOD_SESSION_CACHE_PATH=.robinhood-session/robinhood.pickle

# Recipient used by local live report validation scripts.
PARAKEETNEST_REPORT_RECIPIENT=
