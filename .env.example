# ParakeetNest local integration example.
# Copy to .env locally and fill real values there. Never commit credentials.

PARAKEETNEST_APP_NAME=ParakeetNest
PARAKEETNEST_ENVIRONMENT=development
PARAKEETNEST_LOG_LEVEL=INFO
PARAKEETNEST_LOG_JSON=true
PARAKEETNEST_DATA_DIR=data
PARAKEETNEST_SQLITE_PATH=data/parakeetnest.sqlite3
PARAKEET_REPORT_LANGUAGE=en

# Provider selection. Keep mock values for offline development. The full live
# stack uses Yahoo for market data, news, and financials; FRED for macro; SEC
# EDGAR for filings; Robinhood for portfolio; OpenAI for committee reasoning;
# and Gmail for delivery.
PARAKEETNEST_MARKET_DATA_PROVIDER=mock
PARAKEETNEST_NEWS_PROVIDER=mock
PARAKEETNEST_MACRO_PROVIDER=mock
PARAKEETNEST_SEC_FILINGS_PROVIDER=mock
PARAKEETNEST_FINANCIALS_PROVIDER=mock
PARAKEETNEST_PORTFOLIO_PROVIDER=mock
PARAKEETNEST_EMAIL_PROVIDER=mock

# OpenAI committee provider. Set provider=openai and choose a real model for
# live reports. Never commit a populated API key.
OPENAI_API_KEY=
PARAKEETNEST_LLM_PROVIDER=mock
PARAKEETNEST_LLM_MODEL=mock-committee
PARAKEETNEST_LLM_TEMPERATURE=1
PARAKEETNEST_LLM_TIMEOUT_SECONDS=30
PARAKEETNEST_LLM_MAX_COMPLETION_TOKENS=1000

# FRED macro provider. Set PARAKEETNEST_MACRO_PROVIDER=fred for live data.
FRED_API_KEY=

# Gmail report delivery. Set PARAKEETNEST_EMAIL_PROVIDER=gmail for live email.
# Path to the Google OAuth client credentials JSON.
GOOGLE_APPLICATION_CREDENTIALS=

# Path to the authorized-user OAuth token JSON used by the Gmail send provider.
PARAKEETNEST_GMAIL_TOKEN_PATH=
PARAKEETNEST_SENDER_EMAIL=

# SEC EDGAR provider. Set PARAKEETNEST_SEC_FILINGS_PROVIDER=edgar. SEC requires
# an identifying User-Agent, usually app name plus contact email.
# Quote the value in .env if it contains spaces.
SEC_USER_AGENT=

# Robinhood read-only portfolio provider. Set
# PARAKEETNEST_PORTFOLIO_PROVIDER=robinhood. Prefer a short-lived session token
# when available; otherwise use username and password from the local environment.
PARAKEETNEST_PORTFOLIO_ACCOUNT_ID=
ROBINHOOD_USERNAME=
ROBINHOOD_PASSWORD=
ROBINHOOD_SESSION_TOKEN=
ROBINHOOD_SESSION_CACHE_PATH=.robinhood-session/robinhood.pickle

# Recipient used by local live report validation scripts.
PARAKEETNEST_REPORT_RECIPIENT=
